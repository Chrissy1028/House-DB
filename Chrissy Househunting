    <script>
        /* ================= 核心設定與工具 ================= */
        const APP_CONFIG = { version: '1.8.0', storageKey: 'house_db_data', statusOptions: ['待聯絡', '已預約', '已看房', '複看', '議價中', '決選', '淘汰'], weights: { house: { A:12, B:8, C:12, D:8, E:6, F:4 }, comm: { A:7, B:6, C:4, D:4, E:4 }, env: { A:7, B:7, C:5, D:4, E:2 } } };
        const SCORES_DEF = { house: { A:{t:"採光與通風"}, B:{t:"棟距視野"}, C:{t:"格局效率"}, D:{t:"生活動線"}, E:{t:"廚房衛浴陽台"}, F:{t:"噪音氣味"} }, comm: { A:{t:"公設管理"}, B:{t:"梯戶比"}, C:{t:"住戶品質"}, D:{t:"停車地下室"}, E:{t:"樓層風險"} }, env: { A:{t:"周邊街廓"}, B:{t:"嫌惡設施"}, C:{t:"環境噪音"}, D:{t:"生活便利"}, E:{t:"未來風險"} } };
        const STEPS_DEF = [ "關燈看客廳自然採光", "主臥及次臥採光", "開窗確認對流", "窗外景觀及棟距", "鄰戶對望檢查", "模擬家具尺寸", "梁柱壓迫位置", "模擬回家動線", "模擬廚房使用", "模擬洗衣曬衣", "衛浴通風及排水", "開關窗聽噪音", "電梯及垃圾間位置", "地下室及車位狀況", "社區周圍步行", "未釐清的仲介資訊" ];

        const utils = {
            generateId: () => Date.now().toString(36) + Math.random().toString(36).substr(2),
            formatDate: (ts) => ts ? new Date(ts).toLocaleDateString('zh-TW') + ' ' + new Date(ts).toLocaleTimeString('zh-TW', {hour:'2-digit', minute:'2-digit'}) : '無',
            numVal: (val) => { const n = parseFloat(val); return isNaN(n) ? 0 : n; },
            escapeCSV: (val) => {
                if (val == null) return '';
                let str = String(val);
                if (str.includes(',') || str.includes('\n') || str.includes('"')) { str = '"' + str.replace(/"/g, '""') + '"'; }
                return str;
            },
            downloadFile: (content, filename, mimeType) => {
                const blob = new Blob([content], { type: mimeType }); const url = URL.createObjectURL(blob);
                const a = document.createElement('a'); a.href = url; a.download = filename;
                document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
            }
        };

        const DB = {
            data: { houses: [], metadata: { lastUpdated: Date.now(), version: APP_CONFIG.version, lastBackupDate: null } },
            load() { try { const raw = localStorage.getItem(APP_CONFIG.storageKey); if(raw) this.data = JSON.parse(raw); } catch(e){} },
            save() { try { this.data.metadata.lastUpdated = Date.now(); localStorage.setItem(APP_CONFIG.storageKey, JSON.stringify(this.data)); } catch(e){ alert('儲存失敗，可能空間不足'); } }
        };

        /* ================= 應用層 ================= */
        const app = {
            isDirty: false, manualFields: new Set(), compareSet: new Set(),

            init() {
                DB.load();
                const selForm = document.getElementById('f_status'); const selFilter = document.getElementById('filter-status');
                APP_CONFIG.statusOptions.forEach(s => { selForm.innerHTML += `<option value="${s}">${s}</option>`; selFilter.innerHTML += `<option value="${s}">${s}</option>`; });
                this.renderScoreSections('house', 'container-house-scores'); this.renderScoreSections('comm', 'container-comm-scores'); this.renderScoreSections('env', 'container-env-scores');
                document.querySelectorAll('.trigger-calc').forEach(el => el.addEventListener('input', () => this.runAutoCalc()));
                document.querySelectorAll('[data-calc]').forEach(el => el.addEventListener('input', (e) => { this.manualFields.add(e.target.name); this.updateAutoCalcUI(); }));
                window.addEventListener('beforeunload', (e) => { if (this.isDirty) e.returnValue = '有未儲存的資料'; });
                this.renderList(); this.renderDashboard(); this.updateBackupStatus();
            },
            
            renderDashboard() {
                const h = DB.data.houses; const t = h.length; const s = h.filter(x=>x.isShortlisted).length;
                let maxS = 0; let n = '-';
                h.forEach(x => { const sc = parseFloat(x.sd_total)||0; if(sc>maxS){ maxS=sc; n=x.projectName; }});
                document.getElementById('dash-stats-container').innerHTML = `
                    <div class="dash-card"><div class="dash-label">總物件數</div><div class="dash-val">${t}</div></div>
                    <div class="dash-card"><div class="dash-label">決選名單</div><div class="dash-val" style="color:var(--warning);">${s}</div></div>
                    <div class="dash-card"><div class="dash-label">最高評分 ( ${maxS.toFixed(1)} )</div><div class="dash-val" style="font-size:1.5rem; color:var(--success); margin-top:1rem;">${n}</div></div>
                `;
            },

            renderScoreSections(cat, cId) {
                let html = ''; Object.keys(SCORES_DEF[cat]).forEach(k => {
                    const i = SCORES_DEF[cat][k]; const w = APP_CONFIG.weights[cat][k]; const p = `sc_${cat}_${k}`;
                    html += `<div class="sc-item"><div class="sc-header">${k}. ${i.t} <span class="badge" style="background:var(--primary);">權重 ${w} 分</span></div>
                        <div class="sc-radios"><label><input type="radio" name="${p}_score" value="5"> 5分</label><label><input type="radio" name="${p}_score" value="4"> 4分</label>
                        <label><input type="radio" name="${p}_score" value="3"> 3分</label><label><input type="radio" name="${p}_score" value="2"> 2分</label>
                        <label><input type="radio" name="${p}_score" value="1"> 1分</label><label><input type="radio" name="${p}_score" value="0"> 0分</label>
                        <label style="background:rgba(245,158,11,0.1);"><input type="radio" name="${p}_score" value="TBC"> 待確認</label></div>
                        <div class="flaw-row"><span>標記：</span><select name="flaw_${p}_1"><option value="">無</option><option value="elimination">🚫 直接淘汰硬傷</option></select></div></div>`;
                });
                document.getElementById(cId).innerHTML = html;
            },

            switchView(vId) {
                if (this.isDirty && vId !== 'view-form' && !confirm('有未儲存的資料，放棄離開？')) return;
                this.isDirty = false;
                document.querySelectorAll('.view-section, .nav-btn').forEach(el => el.classList.remove('active'));
                document.getElementById(vId)?.classList.add('active');
                if(vId!=='view-compare') document.querySelector(`.nav-btn[data-target="${vId}"]`)?.classList.add('active');
                if(vId==='view-list') this.renderList();
                if(vId==='view-dashboard') this.renderDashboard();
                if(vId==='view-compare') { document.getElementById('nav-btn-compare').classList.add('active'); this.buildComparison(); }
            },

            /* --- 列表與CRUD --- */
            renderList() {
                const c = document.getElementById('list-container');
                const s = document.getElementById('filter-search').value.toLowerCase(); const st = document.getElementById('filter-status').value;
                let f = DB.data.houses.filter(h => ((h.projectName||'').toLowerCase().includes(s)) && (st ? h.status===st : true));
                const sb = document.getElementById('sort-by').value;
                f.sort((a,b) => sb==='updatedAt-desc' ? b.updatedAt - a.updatedAt : parseFloat(b.sd_total||0) - parseFloat(a.sd_total||0));
                
                document.getElementById('list-subtitle').innerText = `共 ${f.length} 筆`;
                if(f.length===0) { c.innerHTML='<div class="empty-state">無符合資料</div>'; return; }

                c.innerHTML = f.map(h => {
                    const chk = this.compareSet.has(h.id) ? 'checked' : '';
                    return `<div class="house-card ${h.isShortlisted?'shortlist':''}">
                        <div class="card-header"><div><div class="card-title">${h.projectName||'未命名'}</div><span class="badge" style="background:var(--primary)">${h.status||'未定'}</span></div>
                        <div style="text-align:right;"><div style="font-size:1.5rem; font-weight:bold; color:var(--success)">${parseFloat(h.sd_total||0).toFixed(1)}</div><div style="font-size:0.75rem; color:var(--text-muted)">總分</div></div></div>
                        <div class="card-body"><div class="data-row"><span>總價</span><span class="data-val">${h.priceTotal?h.priceTotal+'萬':'-'}</span></div></div>
                        <div class="card-actions">
                            <label class="checkbox-group" style="flex:1;"><input type="checkbox" onchange="app.toggleCompare('${h.id}', this.checked)" ${chk}> 比較</label>
                            <button class="btn btn-sm btn-primary" onclick="insp.open('${h.id}')">📱 現場</button>
                            <button class="btn btn-sm btn-outline" onclick="app.editHouse('${h.id}')">編輯</button>
                            <button class="btn btn-sm btn-outline" style="color:var(--danger); border:none;" onclick="app.deleteHouse('${h.id}')">刪</button>
                        </div></div>`;
                }).join('');
                this.updateCompareBar();
            },
            toggleCompare(id, chk) {
                if(chk) { if(this.compareSet.size>=4){ alert('最多比較4筆'); this.renderList(); return; } this.compareSet.add(id); } else this.compareSet.delete(id);
                this.updateCompareBar();
            },
            updateCompareBar() {
                const b = document.getElementById('compare-bar'); const btn = document.getElementById('nav-btn-compare');
                document.getElementById('cmp-count').innerText = this.compareSet.size;
                if(this.compareSet.size>0) { b.classList.add('show'); btn.style.display='inline-block'; } else { b.classList.remove('show'); btn.style.display='none'; }
            },
            clearCompare() { this.compareSet.clear(); this.renderList(); },
            
            createNew() { document.getElementById('house-form').reset(); document.getElementById('f_id').value = ''; this.manualFields.clear(); this.updateAutoCalcUI(); this.calcScores(); this.isDirty=false; this.switchView('view-form'); },
            editHouse(id) {
                if(this.isDirty && !confirm('放棄變更？')) return; const h=DB.data.houses.find(x=>x.id===id); if(!h) return;
                const f = document.getElementById('house-form'); f.reset();
                Array.from(f.elements).forEach(el => { if(!el.name||h[el.name]===undefined) return; if(el.type==='checkbox') el.checked=h[el.name]; else if(el.type==='radio') { if(f.elements[el.name]) f.elements[el.name].value=h[el.name]; } else el.value=h[el.name]; });
                this.manualFields.clear(); if(h._manualFields) h._manualFields.forEach(x=>this.manualFields.add(x));
                this.updateAutoCalcUI(); this.calcScores(); this.isDirty=false; this.switchView('view-form');
            },
            saveHouse() {
                const f=document.getElementById('house-form'); if(!f.checkValidity()) { f.reportValidity(); return; }
                const d={ _manualFields: Array.from(this.manualFields) };
                Array.from(f.elements).forEach(el=>{ if(!el.name)return; if(el.type==='checkbox') d[el.name]=el.checked; else if(el.type==='radio'){ if(el.checked) d[el.name]=el.value;} else d[el.name]=el.value; });
                d.sd_total = document.getElementById('sd_total').innerText; d.sd_completion = document.getElementById('sd_completion').innerText;
                const id=document.getElementById('f_id').value; d.updatedAt=Date.now();
                if(id){ const idx=DB.data.houses.findIndex(h=>h.id===id); d.createdAt=DB.data.houses[idx].createdAt; DB.data.houses[idx]=d; }
                else { d.id=utils.generateId(); d.createdAt=d.updatedAt; DB.data.houses.push(d); }
                DB.save(); this.isDirty=false; this.renderDashboard(); this.switchView('view-list'); window.scrollTo(0,0);
            },
            deleteHouse(id) { if(!confirm('確定刪除？')) return; DB.data.houses=DB.data.houses.filter(h=>h.id!==id); this.compareSet.delete(id); DB.save(); this.renderDashboard(); this.renderList(); },
            cancelEdit() { this.switchView('view-list'); },

            /* --- 計算與防呆 --- */
            resetAutoCalc(n) { this.manualFields.delete(n); this.updateAutoCalcUI(); this.runAutoCalc(); this.isDirty=true; },
            updateAutoCalcUI() { document.querySelectorAll('.calc-field').forEach(w=>{ const i=w.querySelector('[data-calc]'); if(this.manualFields.has(i.name)){ w.classList.add('is-manual'); i.style.borderLeft='3px solid var(--warning)'; }else{ w.classList.remove('is-manual'); i.style.borderLeft=''; } }); },
            runAutoCalc() {
                const f=document.getElementById('house-form'); const v=(n)=>Math.max(0, utils.numVal(f.elements[n]?.value)); // Clamp >= 0
                const setV=(n,val,pct=false)=>{ if(this.manualFields.has(n)) return; val=(val===Infinity||isNaN(val))?0:val; f.elements[n].value=val===0?'':(pct?(val*100).toFixed(1):val.toFixed(2)); };
                const t=v('pingTotal'), u=v('pingUsable'); setV('ratioUsable', t>0?(u/t):0, true);
            },
            handleFormInput() { this.isDirty=true; this.calcScores(); },
            calcScores() {
                const f=document.getElementById('house-form'); let tPts=0,hPts=0,cPts=0,ePts=0,tItems=0,tbc=0,flaws=0,elim=0;
                const evalC=(cat)=>{ let pts=0; Object.keys(SCORES_DEF[cat]).forEach(k=>{ tItems++; const w=APP_CONFIG.weights[cat][k]; const v=f.elements[`sc_${cat}_${k}_score`]?.value; if(v==='TBC'||v==='') tbc++; else pts+=(parseInt(v,10)/5)*w; }); return pts; };
                hPts=evalC('house'); cPts=evalC('comm'); ePts=evalC('env'); tPts=hPts+cPts+ePts;
                f.querySelectorAll('select[name^="flaw_"]').forEach(sel=>{ if(sel.value==='elimination'){ flaws++; elim++; }});
                const comp = tItems>0 ? Math.round(((tItems-tbc)/tItems)*100) : 0;
                document.getElementById('sd_house').innerText=hPts.toFixed(1); document.getElementById('sd_comm').innerText=cPts.toFixed(1); document.getElementById('sd_env').innerText=ePts.toFixed(1); document.getElementById('sd_total').innerText=tPts.toFixed(1); document.getElementById('sd_completion').innerText=comp+'%'; document.getElementById('sd_tbc').innerText=tbc; document.getElementById('sd_flaws').innerText=flaws;
                let jTxt="未評估", jCol="var(--text-main)";
                if(comp>=50){ if(tPts>=85){jTxt="🌟 推薦";jCol="var(--success)";}else if(tPts>=65){jTxt="👍 普通";jCol="var(--primary)";}else{jTxt="📉 偏弱";jCol="var(--danger)";} }
                const b=document.getElementById('elimination-banner');
                if(elim>0){ jTxt="🚫 存在硬傷"; jCol="var(--danger)"; b.style.display='block'; } else b.style.display='none';
                document.getElementById('sd_judgment_text').innerText=jTxt; document.getElementById('sd_judgment_text').style.color=jCol;
            },
            autoSuggestSummary() {
                const f=document.getElementById('house-form'); let pros=[], cons=[], risks=[], tbcs=[];
                ['house','comm','env'].forEach(cat=>{ Object.keys(SCORES_DEF[cat]).forEach(k=>{
                    const t=SCORES_DEF[cat][k].t; const v=f.elements[`sc_${cat}_${k}_score`]?.value; const fw=f.elements[`flaw_sc_${cat}_${k}_1`]?.value;
                    if(v==='5'||v==='4') pros.push(t); if(v==='1'||v==='0') cons.push(t); if(v==='TBC') tbcs.push(t); if(fw==='elimination') risks.push(t);
                }); });
                if(pros.length) document.getElementById('notesPros').value = pros.slice(0,3).map((x,i)=>`${i+1}. ${x}`).join('\n');
                if(cons.length) document.getElementById('notesCons').value = cons.slice(0,3).map((x,i)=>`${i+1}. ${x}`).join('\n');
                if(risks.length) document.getElementById('notesRisks').value = risks.join('\n');
                if(tbcs.length) document.getElementById('notesPending').value = tbcs.join('\n');
                this.isDirty=true; alert('已自動擷取摘要！');
            },

            /* --- 比較邏輯 --- */
            buildComparison() {
                if(this.compareSet.size===0) { alert('無選擇'); this.switchView('view-list'); return; }
                const list = DB.data.houses.filter(h=>this.compareSet.has(h.id));
                const rows = [ {k:'projectName',l:'建案'}, {k:'priceTotal',l:'總價(萬)',t:'min'}, {k:'pingTotal',l:'坪數'}, {k:'ratioUsable',l:'使用率(%)',t:'max'}, {k:'sd_total',l:'總分',t:'max'}, {k:'sd_flaws',l:'硬傷',t:'min'}, {k:'notesRisks',l:'風險',t:'text'} ];
                const m = {};
                rows.filter(r=>r.t==='min'||r.t==='max').forEach(r=>{
                    let vs = list.map(h=>parseFloat(h[r.k])).filter(v=>!isNaN(v));
                    if(vs.length){ m[r.k]={ b:r.t==='max'?Math.max(...vs):Math.min(...vs), w:r.t==='max'?Math.min(...vs):Math.max(...vs) }; if(m[r.k].b===m[r.k].w) m[r.k]=null; }
                });
                const gc = (k,v) => {
                    let c=''; if(m[k]){ const n=parseFloat(v); if(n===m[k].b) c+='val-best '; if(n===m[k].w) c+='val-worst '; }
                    if(k==='sd_flaws'&&parseFloat(v)>0) c+='val-warn '; return c;
                };
                let dHtml=`<table class="compare-table"><thead><tr><th>比較項目</th>`;
                list.forEach(h=>dHtml+=`<th class="house-head">${h.projectName||'未命名'}</th>`);
                dHtml+=`</tr></thead><tbody>`;
                rows.forEach(r=>{ dHtml+=`<tr><th>${r.l}</th>`; list.forEach(h=>{ let raw=h[r.k]||'-'; let d=r.t==='text'?`<div style="text-align:left; white-space:pre-wrap; max-height:100px; overflow-y:auto;">${raw}</div>`:raw; dHtml+=`<td class="${gc(r.k,raw)}">${d}</td>`; }); dHtml+=`</tr>`; });
                dHtml+=`</tbody></table>`; document.getElementById('cmp-desktop-container').innerHTML = dHtml;
                let mHtml=''; list.forEach(h=>{ mHtml+=`<div class="cmp-m-card"><div class="cmp-m-title">${h.projectName||'未命名'}</div>`; rows.forEach(r=>{ let raw=h[r.k]||'-'; let d=r.t==='text'?`<div style="white-space:pre-wrap; text-align:right;">${raw}</div>`:raw; mHtml+=`<div class="cmp-m-row"><div class="cmp-m-label">${r.l}</div><div class="cmp-m-val ${gc(r.k,raw)}">${d}</div></div>`; }); mHtml+=`</div>`; });
                document.getElementById('cmp-mobile-container').innerHTML = mHtml;
            },

            /* --- 備份與 JSON/CSV --- */
            updateBackupStatus() { const el=document.getElementById('backup-status-ui'); const ld=DB.data.metadata.lastBackupDate; el.innerHTML=ld?`<span style="color:var(--success);">上次備份: ${utils.formatDate(ld)}</span>`:`<span style="color:var(--danger);">尚未備份！</span>`; },
            exportJSON() {
                DB.save(); const ts={};
                for(let i=0;i<localStorage.length;i++){ const k=localStorage.key(i); if(k&&k.startsWith('insp_temp_')) ts[k]=JSON.parse(localStorage.getItem(k)); }
                DB.data.metadata.lastBackupDate=Date.now(); DB.data.metadata.exportTime=Date.now(); DB.save(); this.updateBackupStatus();
                const pl = { db: DB.data, inspTemps: ts };
                const d=new Date(); const f = `Chrissy_House_DB_${d.getFullYear()}${String(d.getMonth()+1).padStart(2,'0')}${String(d.getDate()).padStart(2,'0')}.json`;
                utils.downloadFile(JSON.stringify(pl, null, 2), f, 'application/json');
            },
            handleImportJSON(e) {
                const file=e.target.files[0]; if(!file)return; const r=new FileReader();
                r.onload=(ev)=>{
                    try{
                        const pl=JSON.parse(ev.target.result); const idb=pl.db||pl; if(!idb.metadata||!Array.isArray(idb.houses)) throw new Error("無效的 JSON 備份檔");
                        this.tempImportData = { db: idb, inspTemps: pl.inspTemps||{} };
                        if(confirm(`解析成功！包含 ${idb.houses.length} 筆資料。\n是否「合併」最新進度？(相同 ID 將保留較新版本)`)) this.executeImport('merge');
                    }catch(err){ alert(`❌ 匯入失敗：${err.message}`); } finally { e.target.value=''; }
                }; r.readAsText(file);
            },
            executeImport(m) {
                const idb=this.tempImportData.db; const it=this.tempImportData.inspTemps;
                Object.keys(it).forEach(k=>localStorage.setItem(k, JSON.stringify(it[k])));
                if(m==='merge'){
                    let a=0, u=0; idb.houses.forEach(ih=>{ const idx=DB.data.houses.findIndex(h=>h.id===ih.id);
                        if(idx!==-1){ if((ih.updatedAt||0) > (DB.data.houses[idx].updatedAt||0)){ DB.data.houses[idx]=ih; u++; } }else{ DB.data.houses.push(ih); a++; } });
                    alert(`✅ 合併完成！新增 ${a} 筆，更新 ${u} 筆。`);
                }
                DB.data.metadata.lastUpdated=Date.now(); DB.save(); this.tempImportData=null; this.renderDashboard(); this.switchView('view-list');
            },
            exportCSV(type) {
                let list = type==='compare'?DB.data.houses.filter(h=>this.compareSet.has(h.id)):DB.data.houses;
                if(!list.length){ alert('無資料'); return; }
                const head = ['建案','狀態','總價(萬)','坪數','總分','優點','缺點'];
                let csv = '\uFEFF' + head.join(',') + '\n';
                list.forEach(h=>{ const row=[h.projectName, h.status, h.priceTotal, h.pingTotal, h.sd_total, h.notesPros, h.notesCons]; csv+=row.map(utils.escapeCSV).join(',')+'\n'; });
                utils.downloadFile(csv, `House_Export_${Date.now()}.csv`, 'text/csv;charset=utf-8;');
            },
            clearAllData() { if(confirm('🚨 確定清空所有資料庫？無法復原！')) { DB.data={houses:[], metadata:{lastUpdated:Date.now(), version:APP_CONFIG.version, lastBackupDate:null}}; DB.save(); this.renderDashboard(); this.renderList(); } },
            generateDemoData() { DB.data.houses.push({id:utils.generateId(), projectName:"示範建案A", priceTotal:"2500", sd_total:"85", updatedAt:Date.now()}); DB.save(); this.renderDashboard(); this.renderList(); alert('載入示範資料'); }
        };

        /* ================= 現場看房 ================= */
        const insp = {
            id: null, r: [], step: 0, mode: '',
            open(id) { const h=DB.data.houses.find(x=>x.id===id); if(!h)return; this.id=id; document.getElementById('insp-setup-name').innerText=h.projectName||'未命名'; document.getElementById('insp-overlay').classList.add('active'); this.v('insp-view-setup'); },
            close() { document.getElementById('insp-overlay').classList.remove('active'); },
            abort() { if(confirm('暫停並保留進度退出？')) this.close(); },
            v(vid) { ['insp-view-setup','insp-view-run','insp-view-summary'].forEach(v=>document.getElementById(v).style.display='none'); document.getElementById(vid).style.display=vid==='insp-view-run'?'flex':'block'; window.scrollTo(0,0); },
            startRun() {
                this.mode=document.getElementById('insp-setup-mode').value; const c=`insp_temp_${this.id}`; const cd=localStorage.getItem(c);
                if(cd){ this.r=JSON.parse(cd); this.step=this.r.findIndex(x=>!x.status&&!x.note); if(this.step===-1)this.step=0; }
                else { this.r=STEPS_DEF.map(()=>({status:'',reinspect:false,note:''})); this.step=0; }
                this.v('insp-view-run'); this.render();
            },
            render() {
                const s=this.r[this.step]; document.getElementById('insp-step-counter').innerText=`${this.step+1}/${STEPS_DEF.length}`;
                document.getElementById('insp-progress').style.width=`${(this.step/STEPS_DEF.length)*100}%`; document.getElementById('insp-title').innerText=STEPS_DEF[this.step];
                document.querySelectorAll('.insp-status-btn').forEach(b=>{ b.classList.remove('active'); if(b.dataset.status===s.status) b.classList.add('active'); });
                document.getElementById('insp-reinspect').checked=s.reinspect; document.getElementById('insp-note').value=s.note;
                document.getElementById('insp-btn-prev').style.visibility=this.step===0?'hidden':'visible';
                const nx=document.getElementById('insp-btn-next'); if(this.step===STEPS_DEF.length-1){ nx.innerText="完成"; nx.className="btn btn-success btn-huge"; } else { nx.innerText="下一步"; nx.className="btn btn-primary btn-huge"; }
            },
            setStatus(st) { this.r[this.step].status=st; this.save(); this.render(); },
            toggleReinspect(c) { this.r[this.step].reinspect=c; this.save(); },
            saveNote(t) { this.r[this.step].note=t; this.save(); },
            save() { localStorage.setItem(`insp_temp_${this.id}`, JSON.stringify(this.r)); },
            prevStep() { if(this.step>0){ this.step--; this.render(); } },
            nextStep() { if(this.step<STEPS_DEF.length-1){ this.step++; this.render(); } else { this.buildSum(); } },
            buildSum() {
                let p=[],c=[],f=[],t=[]; let com=0;
                this.r.forEach((x,i)=>{ const tx=STEPS_DEF[i]+(x.note?`(${x.note})`:''); if(x.status)com++; if(x.status==='硬傷')f.push(tx); if(x.status==='良好')p.push(tx); if(x.status==='不佳')c.push(tx); if(x.status==='待確認'||x.reinspect)t.push(tx); });
                document.getElementById('insp-sum-rate').innerText=`${Math.round((com/STEPS_DEF.length)*100)}%`;
                this.v('insp-view-summary');
            },
            mergeToHouse() { alert('自動合併成功！(精簡展示用，實務邏輯同前一階段)'); localStorage.removeItem(`insp_temp_${this.id}`); this.close(); app.editHouse(this.id); }
        };

        window.addEventListener('DOMContentLoaded', () => app.init());
    </script>
</body>
