                <div class="insp-step-title" id="insp-title"></div>
                <div class="insp-status-grid">
                    <button class="insp-status-btn s-good" data-status="良好" onclick="insp.setStatus('良好')">😀 良好</button>
                    <button class="insp-status-btn" data-status="普通" onclick="insp.setStatus('普通')">😐 普通</button>
                    <button class="insp-status-btn s-poor" data-status="不佳" onclick="insp.setStatus('不佳')">😟 不佳</button>
