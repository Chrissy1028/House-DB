                </div>
                <div class="insp-reinspect-box" onclick="document.getElementById('insp-reinspect').click()"><input type="checkbox" id="insp-reinspect" onchange="insp.toggleReinspect(this.checked)"><label>加入下次複看必查</label></div>
                <div class="form-group"><label>語音/文字備註</label><textarea id="insp-note" placeholder="可使用麥克風語音輸入..." oninput="insp.saveNote(this.value)"></textarea></div>
